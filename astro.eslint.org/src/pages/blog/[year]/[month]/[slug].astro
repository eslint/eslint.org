---
import { getCollection, render } from "astro:content";
import Hero from "~/components/Hero.astro";
import ProfileAuthor from "~/components/ProfileAuthor.astro";
import Layout from "~/layouts/Layout.astro";
import Footer from "~/partials/Footer.astro";
import FromTheBlog from "~/partials/FromTheBlog.astro";
import Header from "~/partials/Header.astro";
import PostSidebar from "~/partials/PostSidebar.astro";
import { getAuthorEntries } from "~/utils/authors";
import { formatBlogDate, getPostDate, getPostSlug, sortBlogPosts } from "~/utils/blog";
import { slugify } from "~/utils/slugify";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => {
    const date = getPostDate(post);

    return {
      params: {
        year: String(date.getUTCFullYear()),
        month: String(date.getUTCMonth() + 1).padStart(2, "0"),
        slug: getPostSlug(post),
      },
      props: { post },
    };
  });
}

const { post: entry } = Astro.props;
const morePosts = sortBlogPosts(await getCollection("blog"))
  .filter((item) => item.id !== entry.id)
  .slice(0, 3);
const { Content } = await render(entry);
const data = entry.data;
const date = getPostDate(entry);
const dateText = formatBlogDate(date);
const primaryCategory = data.categories[0];
const categorySlug = slugify(primaryCategory);
---

<Layout
  {...Astro.props}
  title={data.title}
  description={data.teaser}
  image={data.image}
  categories={data.categories}
  original={data.original}
  bodyClass="post blog-post-page"
>
  <Header />

  <script src="https://unpkg.com/anchor-js@4.3.1/anchor.min.js"></script>

  <main id="main" class="post-main" tabindex="-1">
    <Hero
      title={data.title}
      supportingText={data.teaser}
      post={{
        date: dateText,
        category: primaryCategory,
        categoryURL: categorySlug,
      }}
    />

    <div class="content-container grid">
      <div class="post__blog-content span-5-12">
        <Content />
      </div>

      <div class="post__author-bios span-5-12">
        {
          getAuthorEntries(data.authors).map(({ data }) => <ProfileAuthor data={data} />)
        }
      </div>

      <PostSidebar post={entry} />
    </div>
  </main>

  <FromTheBlog morePosts={morePosts} />

  <Footer multilingual={false} />

  <div
    id="copy-announcement"
    class="visually-hidden"
    aria-live="polite"
    aria-atomic="true"></div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const anchors = Object.getOwnPropertyDescriptor(globalThis, "anchors")?.value;

      if (anchors && typeof anchors === "object" && "add" in anchors && typeof anchors.add === "function") {
        anchors.add(".post__blog-content h2, .post__blog-content h3, .post__blog-content h4");
      }
    });

    const copyIcon = `<svg width="20" height="20" viewBox="0 0 20 20" role="img" aria-label="copy" fill="none" focusable="false">
      <path d="M4.16667 12.5H3.33333C2.89131 12.5 2.46738 12.3244 2.15482 12.0118C1.84226 11.6993 1.66667 11.2754 1.66667 10.8333V3.33332C1.66667 2.8913 1.84226 2.46737 2.15482 2.15481C2.46738 1.84225 2.89131 1.66666 3.33333 1.66666H10.8333C11.2754 1.66666 11.6993 1.84225 12.0118 2.15481C12.3244 2.46737 12.5 2.8913 12.5 3.33332V4.16666M9.16667 7.49999H16.6667C17.5871 7.49999 18.3333 8.24618 18.3333 9.16666V16.6667C18.3333 17.5871 17.5871 18.3333 16.6667 18.3333H9.16667C8.24619 18.3333 7.5 17.5871 7.5 16.6667V9.16666C7.5 8.24618 8.24619 7.49999 9.16667 7.49999Z" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round" />
    </svg>`;
    const announcementRegion = document.getElementById("copy-announcement");
    const shareBtn = document.getElementById("post-url-share-btn");
    const shareAnnouncementRegion = document.getElementById("ctc-announcement");

    document.querySelectorAll(".post__blog-content pre").forEach((pre, index) => {
      if (pre.parentElement?.classList.contains("code-wrapper")) {
        return;
      }

      const labelId = `copy-button-label-${index}`;
      const wrapper = document.createElement("div");
      const copyBtn = document.createElement("button");

      wrapper.className = "code-wrapper";
      copyBtn.className = "copy-btn";
      copyBtn.type = "button";
      copyBtn.setAttribute("aria-labelledby", labelId);
      copyBtn.innerHTML = `<span hidden id="${labelId}">Copy code to clipboard</span>${copyIcon}`;

      pre.before(wrapper);
      wrapper.append(pre, copyBtn);
    });

    shareBtn?.removeAttribute("hidden");
    shareBtn?.addEventListener("click", () => {
      navigator.clipboard.writeText(window.location.href);
      shareAnnouncementRegion?.replaceChildren("Copied to clipboard.");
      shareAnnouncementRegion?.setAttribute("data-fades-out", "true");
      shareBtn.setAttribute("data-copied", "true");

      setTimeout(() => {
        shareAnnouncementRegion?.replaceChildren();
        shareAnnouncementRegion?.removeAttribute("data-fades-out");
        shareBtn.removeAttribute("data-copied");
      }, 4000);
    });

    const copyBtns = document.querySelectorAll(".copy-btn");

    for (const copyBtn of copyBtns) {
      const copyText = copyBtn.previousElementSibling?.firstChild?.textContent;

      copyBtn.addEventListener("click", () => {
        if (!copyText || !announcementRegion) {
          return;
        }

        navigator.clipboard
          .writeText(copyText)
          .then(() => {
            announcementRegion.innerHTML = "Copied!";
            copyBtn.setAttribute("data-copied", "true");

            setTimeout(() => {
              copyBtn.removeAttribute("data-copied");
              announcementRegion.innerHTML = "";
            }, 2000);
          })
          .catch((err) => {
            announcementRegion.innerHTML = "Failed to copy!";
            console.error("Clipboard write failed: ", err);
          });
      });
    }
  </script>
</Layout>
