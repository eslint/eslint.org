---
import { getEntry } from "astro:content";
import Main from "~/layouts/Main.astro";
import Donation from "~/components/Donation.astro";
import Hero from "~/components/Hero.astro";
import donations from "~/data/donations.json";
import sponsors from "~/data/sponsors.json";
import techsponsors from "~/data/techsponsors.json";
import { getSiteStaticPaths } from "~/utils/i18n";

export async function getStaticPaths() {
  return getSiteStaticPaths();
}

const site = (await getEntry("sites", Astro.currentLocale!))?.data as any;
const formatCurrency = (amount: number) =>
  new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
  }).format(amount);
const formatDate = (date: string) =>
  new Intl.DateTimeFormat("en-US", {
    dateStyle: "long",
    timeZone: "UTC",
  }).format(new Date(date));
const fallbackImage = "/assets/images/people/_placeholder-avatar.svg";
---
<Main>
  <Hero
    title={site.sponsors_page.title}
    supportingText={site.sponsors_page.description
      .replace("BACKER_COUNT", sponsors.totals.sponsorCount)
      .replace(
        "MONTHLY_DONATIONS",
        formatCurrency(sponsors.totals.monthlyDonations),
      )}
    buttons={{
      primary: {
        primaryText: site.sponsors_page.hero.cta.text,
        primaryURL: site.sponsors_page.hero.cta.url,
      },
    }}
  />

  <section class="section">
    {
      (["diamond", "platinum", "gold", "silver", "bronze"] as const).map(
        (tier) =>
          sponsors[tier].length > 0 && (
            <div class="content-container grid grid--center-items">
              <div class="span-1-5">
                <h2 class="section-title h4" id={tier}>
                  {site.sponsors_page.tiers[tier].title}
                </h2>
                <p>{site.sponsors_page.tiers[tier].description}</p>
              </div>
              <div class="span-7-12">
                <ul role="list" class={`sponsors sponsors--${tier}`}>
                  {sponsors[tier].map((sponsor: any) => {
                    const sponsorTitle = site.sponsors_page.sponsor_title
                      .replace("SPONSOR_NAME", sponsor.name)
                      .replace(
                        "AMOUNT",
                        formatCurrency(sponsor.monthlyDonation),
                      );

                    return (
                      <li>
                        <a
                          href={sponsor.url}
                          class="sponsor-link"
                          rel="nofollow noopener sponsored"
                          target="_blank"
                        >
                          <img
                            loading="lazy"
                            decoding="async"
                            src={sponsor.image}
                            height="128"
                            alt={sponsorTitle}
                            title={sponsorTitle}
                          />
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            </div>
          ),
      )
    }
    <div class="content-container grid grid--center-items">
      <div class="span-1-5">
        <h2 class="section-title h4" id="technology">
          {site.sponsors_page.tiers.technology.title}
        </h2>
        <p>{site.sponsors_page.tiers.technology.description}</p>
      </div>
      <div class="span-7-12">
        <ul role="list" class="sponsors sponsors--technology">
          {
            techsponsors.map((sponsor: any) => {
              const sponsorTitle = site.sponsors_page.tech_sponsor_title
                .replace("SPONSOR_NAME", sponsor.name)
                .replace(
                  "TECH",
                  sponsor.donation.charAt(0).toUpperCase() +
                    sponsor.donation.slice(1),
                );

              return (
                <li>
                  <a
                    href={sponsor.url}
                    class="sponsor-link"
                    rel="nofollow noopener sponsored"
                    target="_blank"
                  >
                    <img
                      loading="lazy"
                      decoding="async"
                      src={sponsor.image}
                      alt={sponsorTitle}
                      title={sponsorTitle}
                      height="64"
                    />
                  </a>
                </li>
              );
            })
          }
        </ul>
      </div>
    </div>
  </section>

  <section id="donations">
    <div class="content-container divider">
      <div class="section-head center-text">
        <h2 class="section-title h3" id="donations-label">
          {site.sponsors_page.recent_donations.title}
        </h2>
        <p class="section-supporting-text fs-step-0">
          {site.sponsors_page.recent_donations.description}
        </p>
      </div>
      <ul
        role="list"
        class="donations-list"
        tabindex="-1"
        aria-labelledby="donations-label"
      >
        {
          donations.slice(0, 50).map((donation: any) => (
            <li class="donations-item">
              <Donation
                image={donation.image}
                name={donation.name}
                amount={formatCurrency(donation.amount)}
                date={formatDate(donation.date)}
              />
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section>
    <div class="content-container divider">
      <div class="section-head center-text">
        <h2 class="section-title h3">
          {site.sponsors_page.tiers.backers.title}
        </h2>
        <p class="section-supporting-text fs-step-0">
          {site.sponsors_page.tiers.backers.description}
        </p>
      </div>
      <div class="grid">
        <ul role="list" class="sponsors span-1-12 sponsors--backers">
          {
            sponsors.backers.map((sponsor: any) => {
              const sponsorTitle = `${sponsor.name || "Anonymous"} is donating ${formatCurrency(sponsor.monthlyDonation)} each month`;

              return (
                <li>
                  <a
                    href={sponsor.url}
                    class="sponsor-link"
                    rel="nofollow noopener sponsored"
                    target="_blank"
                  >
                    <img
                      loading="lazy"
                      decoding="async"
                      src={sponsor.image || fallbackImage}
                      height="48"
                      width="48"
                      onerror={`this.src = '${fallbackImage}'`}
                      alt={sponsorTitle}
                      title={sponsorTitle}
                    />
                  </a>
                </li>
              );
            })
          }
        </ul>
      </div>
    </div>
  </section>
</Main>
