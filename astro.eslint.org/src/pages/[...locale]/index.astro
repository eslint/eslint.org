---
import { getCollection, getEntry } from "astro:content";
import Main from "~/layouts/Main.astro";
import Ad from "~/partials/Ad.astro";
import BlogCard from "~/components/BlogCard.astro";
import Donation from "~/components/Donation.astro";
import HeaderAnimation from "~/components/HeaderAnimation.astro";
import StatItem from "~/components/StatItem.astro";
import TestimonialsSlider from "~/components/TestimonialsSlider.astro";
import { sortBlogPosts } from "~/utils/blog";
import donations from "~/data/donations.json";
import links from "~/data/links.json";
import sponsors from "~/data/sponsors.json";
import stats from "~/data/stats.json";
import techsponsors from "~/data/techsponsors.json";
import { getRelativeLocaleUrl } from "astro:i18n";
import { getSiteStaticPaths } from "~/utils/i18n";

export async function getStaticPaths() {
  return getSiteStaticPaths();
}

const site = (await getEntry("sites", Astro.currentLocale!))?.data as any;
const withLocale = (url: string) => getRelativeLocaleUrl(Astro.currentLocale!, url);

const latestPosts = sortBlogPosts(await getCollection("blog"))
  .slice(0, 3);

const formatCurrency = (amount: number) =>
  new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
  }).format(amount);
  
const formatDate = (date: string) =>
  new Intl.DateTimeFormat("en-US", {
    dateStyle: "long",
    timeZone: "UTC",
  }).format(new Date(date));

const versionLine = (version: string, date: string) =>
  site.homepage.versions.dateline
    .replace(
      "VERSION",
      `<a href="https://github.com/eslint/eslint/releases/tag/${version}" class="text-dark no-underline">${version}</a>`,
    )
    .replace("DATE", formatDate(date));
---

<Main>
  <section class="section hero hero--homepage">
    <div class="content-container grid">
      <div class="span-1-7 content-container">
        <div>
          <div class="section-head">
            {
              site.homepage.animation.enabled ? (
                <>
                  <h1 class="visually-hidden">{site.homepage.title}</h1>
                  <HeaderAnimation site={site} />
                </>
              ) : (
                <h1 class="section-title">{site.homepage.title}</h1>
              )
            }
            <p class="section-supporting-text">{site.homepage.description}</p>
          </div>

          <div class="eslint-install-code-wrapper">
            <div
              class="eslint-install-code"
              role="region"
              aria-labelledby="eslint-installation"
            >
              <span hidden id="eslint-installation"
                >{site.homepage.install.title}</span
              >
              <button
                class="eslint-install-code__btn"
                id="copyBtn"
                aria-labelledby="copy-button-label"
              >
                <span hidden id="copy-button-label"
                  >{site.homepage.install.title}</span
                >
                <svg width="20" height="20" viewBox="0 0 20 20" class="c-icon" role="img" aria-label="copy" fill="none" focusable="false">
                  <path d="M4.16667 12.5H3.33333C2.89131 12.5 2.46738 12.3244 2.15482 12.0118C1.84226 11.6993 1.66667 11.2754 1.66667 10.8333V3.33332C1.66667 2.8913 1.84226 2.46737 2.15482 2.15481C2.46738 1.84225 2.89131 1.66666 3.33333 1.66666H10.8333C11.2754 1.66666 11.6993 1.84225 12.0118 2.15481C12.3244 2.46737 12.5 2.8913 12.5 3.33332V4.16666M9.16667 7.49999H16.6667C17.5871 7.49999 18.3333 8.24618 18.3333 9.16666V16.6667C18.3333 17.5871 17.5871 18.3333 16.6667 18.3333H9.16667C8.24619 18.3333 7.5 17.5871 7.5 16.6667V9.16666C7.5 8.24618 8.24619 7.49999 9.16667 7.49999Z" stroke="currentColor" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </button>
              <input
                type="text"
                id="code-snippet"
                value="npm init @eslint/config@latest"
                aria-readonly="true"
                readonly
                tabindex="-1"
                aria-labelledby="eslint-installation"
              />
            </div>
            <span
              id="eslint-install-code__announcement"
              class="eslint-install-code__announcement"
              aria-live="polite"
              aria-atomic="true"></span>
          </div>

          <div class="eslint-actions">
            <a
              href={links.getStarted}
              target="_blank"
              class="c-btn c-btn--primary c-btn--large"
              >{site.shared.get_started}</a
            >
            <a
              href={withLocale(links.donate)}
              class="c-btn c-btn--secondary c-btn--large donate-link"
              >{site.shared.become_a_sponsor}</a
            >
          </div>

          <div class="eslint-top-sponsors">
            <div class="sponsor-text">{site.homepage.sponsor.text}</div>
            <div class="sponsors">
              {
                (["diamond", "platinum", "gold"] as const)
                  .flatMap((tier) => sponsors[tier])
                  .map((sponsor: any) => (
                    <a
                      href={sponsor.url}
                      class="sponsor-link"
                      rel="nofollow noopener sponsored"
                      target="_blank"
                    >
                      <img
                        loading="lazy"
                        decoding="async"
                        src={sponsor.image}
                        height="128"
                        alt={sponsor.name}
                      />
                    </a>
                  ))
              }
              <a href={withLocale("/sponsors/")}>{site.homepage.sponsor.more}</a
              >
            </div>
          </div>
        </div>
      </div>

      <div class="span-10-12 eslint-versions-col">
        <div class="carbon-wrapper">
          <Ad carbonAds={site.carbon_ads} ethicalAds={site.ethical_ads} />
        </div>
        <div class="eslint-versions-container">
          <dl class="eslint-versions" aria-labelledby="eslint-versions-title">
            <span id="eslint-versions-title" hidden
              >{site.homepage.versions.title}</span
            >
            <dt>{site.homepage.versions.latest}</dt>
            <dd>
              <svg width="16" height="8" viewBox="0 0 16 8" class="c-icon" role="img" aria-label="npm">
                  <path d="M0 0.888885H16V6.22222H8V7.11111H4.44444V6.22222H0V0.888885ZM0.888889 5.33333H2.66667V2.66666H3.55556V5.33333H4.44444V1.77777H0.888889V5.33333ZM5.33333 1.77777V6.22222H7.11111V5.33333H8.88889V1.77777H5.33333ZM7.11111 2.66666H8V4.44444H7.11111V2.66666ZM9.77778 1.77777V5.33333H11.5556V2.66666H12.4444V5.33333H13.3333V2.66666H14.2222V5.33333H15.1111V1.77777H9.77778Z" fill="currentColor" />
              </svg>
              <span
                set:html={versionLine(
                  stats.latestVersion,
                  stats.latestVersionDate,
                )}
              />
            </dd>
            {
              stats.currentVersionIsPrerelease && (
                <>
                  <dt>{site.homepage.versions.latest_prerelease}</dt>
                  <dd>
                    <svg width="16" height="8" viewBox="0 0 16 8" class="c-icon" role="img" aria-label="npm">
                      <path d="M0 0.888885H16V6.22222H8V7.11111H4.44444V6.22222H0V0.888885ZM0.888889 5.33333H2.66667V2.66666H3.55556V5.33333H4.44444V1.77777H0.888889V5.33333ZM5.33333 1.77777V6.22222H7.11111V5.33333H8.88889V1.77777H5.33333ZM7.11111 2.66666H8V4.44444H7.11111V2.66666ZM9.77778 1.77777V5.33333H11.5556V2.66666H12.4444V5.33333H13.3333V2.66666H14.2222V5.33333H15.1111V1.77777H9.77778Z" fill="currentColor" />
                    </svg>
                    <span
                      set:html={versionLine(
                        stats.currentVersion,
                        stats.currentVersionDate,
                      )}
                    />
                  </dd>
                </>
              )
            }
            <dt>{site.homepage.versions.upcoming}</dt>
            <dd>
              <svg
                width="16"
                height="16"
                viewBox="0 0 16 16"
                class="c-icon"
                role="img"
                aria-label="Github"
              >
                <path
                  d="M8 0.200012C3.6 0.200012 0 3.80001 0 8.20001C0 11.7333 2.26667 14.7333 5.46667 15.8C5.86667 15.8667 6 15.6 6 15.4C6 15.2 6 14.7333 6 14.0667C3.8 14.5333 3.33333 13 3.33333 13C3 12.0667 2.46667 11.8 2.46667 11.8C1.66667 11.3333 2.46667 11.3333 2.46667 11.3333C3.26667 11.4 3.66667 12.1333 3.66667 12.1333C4.4 13.3333 5.53333 13 6 12.8C6.06667 12.2667 6.26667 11.9333 6.53333 11.7333C4.73333 11.5333 2.86667 10.8667 2.86667 7.80001C2.86667 6.93335 3.2 6.20001 3.66667 5.66668C3.66667 5.40001 3.33333 4.60001 3.8 3.53335C3.8 3.53335 4.46667 3.33335 6 4.33335C6.66667 4.13335 7.33333 4.06668 8 4.06668C8.66667 4.06668 9.33333 4.13335 10 4.33335C11.5333 3.26668 12.2 3.53335 12.2 3.53335C12.6667 4.66668 12.3333 5.46668 12.2667 5.66668C12.8 6.20001 13.0667 6.93335 13.0667 7.80001C13.0667 10.8667 11.2 11.5333 9.4 11.7333C9.66667 12 9.93333 12.4667 9.93333 13.2C9.93333 14.2667 9.93333 15.1333 9.93333 15.4C9.93333 15.6 10.0667 15.8667 10.4667 15.8C13.6667 14.7333 15.9333 11.7333 15.9333 8.20001C16 3.80001 12.4 0.200012 8 0.200012Z"
                  fill="currentColor"></path>
              </svg>
              <span
                set:html={site.homepage.versions.dateline
                  .replace(
                    "VERSION",
                    `<a class="text-dark">${stats.nextVersion}</a>`,
                  )
                  .replace("DATE", formatDate(stats.nextVersionDate))}
              />
            </dd>
            {
              !stats.currentVersionIsPrerelease && (
                <>
                  <dt>{site.homepage.versions.development}</dt>
                  <dd>
                    <svg
                      width="16"
                      height="16"
                      viewBox="0 0 16 16"
                      class="c-icon"
                      role="img"
                      aria-label="Github"
                    >
                      <path
                        d="M8 0.200012C3.6 0.200012 0 3.80001 0 8.20001C0 11.7333 2.26667 14.7333 5.46667 15.8C5.86667 15.8667 6 15.6 6 15.4C6 15.2 6 14.7333 6 14.0667C3.8 14.5333 3.33333 13 3.33333 13C3 12.0667 2.46667 11.8 2.46667 11.8C1.66667 11.3333 2.46667 11.3333 2.46667 11.3333C3.26667 11.4 3.66667 12.1333 3.66667 12.1333C4.4 13.3333 5.53333 13 6 12.8C6.06667 12.2667 6.26667 11.9333 6.53333 11.7333C4.73333 11.5333 2.86667 10.8667 2.86667 7.80001C2.86667 6.93335 3.2 6.20001 3.66667 5.66668C3.66667 5.40001 3.33333 4.60001 3.8 3.53335C3.8 3.53335 4.46667 3.33335 6 4.33335C6.66667 4.13335 7.33333 4.06668 8 4.06668C8.66667 4.06668 9.33333 4.13335 10 4.33335C11.5333 3.26668 12.2 3.53335 12.2 3.53335C12.6667 4.66668 12.3333 5.46668 12.2667 5.66668C12.8 6.20001 13.0667 6.93335 13.0667 7.80001C13.0667 10.8667 11.2 11.5333 9.4 11.7333C9.66667 12 9.93333 12.4667 9.93333 13.2C9.93333 14.2667 9.93333 15.1333 9.93333 15.4C9.93333 15.6 10.0667 15.8667 10.4667 15.8C13.6667 14.7333 15.9333 11.7333 15.9333 8.20001C16 3.80001 12.4 0.200012 8 0.200012Z"
                        fill="currentColor"
                      />
                    </svg>
                    <span
                      set:html={site.homepage.versions.dateline
                        .replace("VERSION", '<a class="text-dark">HEAD</a>')
                        .replace("DATE", formatDate(stats.lastCommitDate))}
                    />
                  </dd>
                </>
              )
            }
          </dl>
          <a href={"/version-support/"}
            >{site.homepage.versions.version_support}</a
          >
        </div>
      </div>
    </div>
  </section>

  <section class="section features-section">
    <div class="content-container">
      <header class="section-head center-text">
        <h2 class="section-title h3">{site.homepage.explainer.title}</h2>
        <p class="section-supporting-text fs-step-0">
          {site.homepage.explainer.description}
        </p>
      </header>
      <div class="section-body features-wrapper grid">
        <div class="features span-1-5">
          {
            site.homepage.explainer.features.map((feature: any) => (
              <article class="feature">
                <h3 class="feature__title">{feature.title}</h3>
                <p class="feature__description">{feature.description}</p>
                <a
                  href={withLocale(
                    links[feature.learn_more.link as keyof typeof links],
                  )}
                  class="feature__details-link"
                >
                  <span set:html={feature.learn_more.text} />
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 20 20"
                    aria-hidden="true"
                    focusable="false"
                  >
                    <path
                      d="M4.16667 9.99996H15.8333M15.8333 9.99996L10 4.16663M15.8333 9.99996L10 15.8333"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </a>
              </article>
            ))
          }
        </div>

        <div class="features-image span-7-12">
          <img
            src="/assets/images/eslint-features-img.png"
            alt={site.homepage.explainer.image.alt}
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="content-container divider">
      <header class="section-head center-text">
        <h2 class="section-title h3" id="latest-posts-label">
          {site.blog_page.title}
        </h2>
        <p class="section-supporting-text fs-step-0">
          {site.blog_page.description}
        </p>
      </header>
      <div class="blog-posts">
        {latestPosts.map((post) => <BlogCard post={post} />)}
      </div>

      <div class="center-text">
        <a href={"/blog/"} class="c-btn c-btn--primary"
          >{site.homepage.blog.view_all_posts}</a
        >
      </div>
    </div>
  </section>

  <section>
    <div class="content-container divider community-section">
      <header class="section-head center-text">
        <h2 class="section-title h3">{site.homepage.stats.title}</h2>
        <p class="section-supporting-text fs-step-0">
          {site.homepage.stats.description.replace(
            "DOWNLOAD_COUNT",
            new Intl.NumberFormat(site.locale).format(stats.weeklyDownloads),
          )}
        </p>
      </header>
      <div class="metrics center-text">
        <StatItem
          value={stats.projectDependents}
          label={site.homepage.stats.dependents}
        />
        <StatItem
          value={stats.weeklyDownloads}
          label={site.homepage.stats.weekly_downloads}
        />
        <StatItem value={stats.stars} label={site.homepage.stats.stars} />
      </div>
    </div>
  </section>

  <section>
    <div class="content-container divider">
      <header class="section-head center-text">
        <h2 class="section-title h3">{site.homepage.sponsors.title}</h2>
        <p class="section-supporting-text fs-step-0">
          {site.homepage.sponsors.description
            .replace(
              "ANNUAL_DONATIONS",
              formatCurrency(sponsors.totals.annualDonations),
            )
            .replace("SPONSOR_COUNT", sponsors.totals.sponsorCount)}
        </p>
      </header>
      <div class="grid">
        <ul role="list" class="sponsors span-4-9">
          {
            (["diamond", "platinum", "gold", "silver", "bronze"] as const)
              .flatMap((tier) => sponsors[tier])
              .map((sponsor: any) => {
                const sponsorTitle = site.sponsors_page.sponsor_title
                  .replace("SPONSOR_NAME", sponsor.name)
                  .replace("AMOUNT", formatCurrency(sponsor.monthlyDonation));

                return (
                  <li>
                    {sponsor.url ? (
                      <a
                        href={sponsor.url}
                        class="sponsor-link"
                        rel="nofollow noopener sponsored"
                        target="_blank"
                      >
                        <img
                          src={sponsor.image}
                          alt={sponsorTitle}
                          title={sponsorTitle}
                          height="48"
                          loading="lazy"
                          decoding="async"
                        />
                      </a>
                    ) : (
                      <img
                        src={sponsor.image}
                        alt={sponsorTitle}
                        title={sponsorTitle}
                        height="48"
                        loading="lazy"
                        decoding="async"
                      />
                    )}
                  </li>
                );
              })
          }
          {
            techsponsors.map((sponsor: any) => {
              const sponsorTitle = site.sponsors_page.tech_sponsor_title
                .replace("SPONSOR_NAME", sponsor.name)
                .replace(
                  "TECH",
                  sponsor.donation.charAt(0).toUpperCase() +
                    sponsor.donation.slice(1),
                );

              return (
                <li>
                  <a href={sponsor.url}>
                    <img
                      src={sponsor.image}
                      alt={sponsorTitle}
                      title={sponsorTitle}
                      width="48"
                      height="48"
                      loading="lazy"
                      decoding="async"
                    />
                  </a>
                </li>
              );
            })
          }
        </ul>
        <div class="center-text">
          <a href={withLocale("/sponsors/")} class="c-btn c-btn--primary"
            >{site.homepage.sponsors.view_all_sponsors}</a
          >
        </div>
      </div>
      <div class="grid">
        <div class="span-3-10">
          <h3 class="donations-title span-5-8" id="donations-label">
            {site.homepage.donations.title}
          </h3>
          <ul
            role="list"
            class="donations-list"
            tabindex="-1"
            aria-labelledby="donations-label"
          >
            {
              donations.slice(0, 6).map((donation: any) => (
                <li class="donations-item">
                  <Donation
                    image={donation.image}
                    name={donation.name}
                    amount={formatCurrency(donation.amount)}
                    date={formatDate(donation.date)}
                  />
                </li>
              ))
            }
          </ul>
        </div>
        <div class="center-text">
          <a
            href={`${withLocale("/sponsors/")}#donations`}
            class="c-btn c-btn--secondary"
            >{site.homepage.donations.view_all_donations}</a
          >
        </div>
      </div>
    </div>
  </section>

  <section aria-labelledby="testimonials-section-label">
    <h2 class="visually-hidden" id="testimonials-section-label">
      {site.donate_page.testimonials.title}
    </h2>
    <div class="content-container">
      <TestimonialsSlider site={site} />
    </div>
  </section>

  <script define:vars={{ copiedMessage: site.homepage.install.copied }}>
    (function() {
        const copyBtn = document.getElementById('copyBtn');
        const copyText = document.getElementById('code-snippet');
        const announcement_region = document.getElementById('eslint-install-code__announcement');
        copyBtn.removeAttribute('hidden');

        copyBtn.onclick = () => {
            copyText.select();
            navigator.clipboard.writeText(copyText.value);
            announcement_region.innerHTML = copiedMessage;
            this.focus();
            copyBtn.setAttribute('data-copied', 'true');

            setTimeout(() => {
                copyBtn.removeAttribute('data-copied');
                announcement_region.innerHTML = "";
                announcement_region.removeAttribute('data-fades-out');
            }, 4000);
        }
    })();
  </script>
</Main>

{
  site.homepage.animation.enabled && (
    <>
      <script
        is:inline
        src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.13.0/gsap.min.js"
      />
      <script
        is:inline
        src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.13.0/Flip.min.js"
      />
      <script is:inline src="/assets/js/animation.js" />
    </>
  )
}
<script is:inline src="/assets/js/hammer.min.js"></script>
<script is:inline src="/assets/js/slider.js"></script>
