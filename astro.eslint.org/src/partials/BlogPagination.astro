---
const { site, page } = Astro.props;
const status = site.blog_page.pagination.status
  .replace("PAGE_NUMBER", String(page.currentPage))
  .replace("TOTAL_PAGE_COUNT", String(page.lastPage));
---

<nav class="c-pagination" aria-labelledby="pagination-label">
  <h2 id="pagination-label" hidden>{site.blog_page.pagination.title}</h2>

  <span class="c-pagination__current c-pagination__item">{status}</span>
  <div class="c-pagination__prev">
    {
      page.currentPage !== 1 ? (
        <a class="c-pagination__item" href={page.url.first}>
          {site.blog_page.pagination.first_page}
        </a>
      ) : (
        <a class="c-pagination__item" role="link" aria-disabled="true">
          {site.blog_page.pagination.first_page}
        </a>
      )
    }
    {
      page.url.prev ? (
        <a class="c-pagination__item" href={page.url.prev}>
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M19 12H5M5 12L12 19M5 12L12 5"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>

          <span class="c-pagination__item__text">
            {site.blog_page.pagination.previous_page}
          </span>
        </a>
      ) : (
        <a class="c-pagination__item" role="link" aria-disabled="true">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M19 12H5M5 12L12 19M5 12L12 5"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          <span class="c-pagination__item__text">
            {site.blog_page.pagination.previous_page}
          </span>
        </a>
      )
    }
  </div>
  <div class="c-pagination__next">
    {
      page.url.next ? (
        <a class="c-pagination__item" href={page.url.next}>
          <span class="c-pagination__item__text">
            {site.blog_page.pagination.next_page}
          </span>
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M5 12H19M19 12L12 5M19 12L12 19"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      ) : (
        <a class="c-pagination__item" role="link" aria-disabled="true">
          <span class="c-pagination__item__text">
            {site.blog_page.pagination.next_page}
          </span>
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M5 12H19M19 12L12 5M19 12L12 19"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      )
    }
    {
      page.currentPage !== page.lastPage ? (
        <a class="c-pagination__item" href={page.url.last}>
          {site.blog_page.pagination.last_page}
        </a>
      ) : (
        <a class="c-pagination__item" role="link" aria-disabled="true">
          {site.blog_page.pagination.last_page}
        </a>
      )
    }
  </div>
</nav>
