---
import { getEntry } from "astro:content";
import helpers from "~/utils/helpers";
import links from "../data/links.json";
import { getRelativeLocaleUrl } from "astro:i18n";

const site = (await getEntry("sites", Astro.currentLocale!))?.data as any;

const pageUrl = Astro.url.pathname;
const getNavigationLink = (item: any) => {
  const url = links[item.link as keyof typeof links];

  return ["blog", "playground"].includes(item.link) || !url.startsWith("/")
    ? url
    : getRelativeLocaleUrl(Astro.currentLocale!, url);
};
---
<nav class="site-nav" aria-label="Main">
  <div class="flexer">
    <a
      href={getRelativeLocaleUrl(Astro.currentLocale!, links.donate)}
      class="c-btn c-btn--primary donate-link"
      >{site?.donate_page.title}</a
    >
    <button
      class="site-nav-toggle"
      aria-label="Menu"
      id="nav-toggle"
      aria-controls="nav-list"
    >
      <svg width="20" height="20" viewBox="20 20 60 60">
        <path id="ham-top" d="M30,37 L70,37 Z" stroke="currentColor"></path>
        <path id="ham-middle" d="M30,50 L70,50 Z" stroke="currentColor"></path>
        <path id="ham-bottom" d="M30,63 L70,63 Z" stroke="currentColor"></path>
      </svg>
    </button>
  </div>
  <ul id="nav-list" class="nav-list-with-js">
    {
      site?.navigation.map((item: any) => {
        const itemLink = getNavigationLink(item);

        return (
          <li>
            <a
              href={itemLink}
              target={item.target}
              {...helpers.getLinkActiveState(itemLink, pageUrl)}
            >
              {item.text}
            </a>
          </li>
        );
      })
    }
  </ul>
  <details class="nav-no-js">
    <summary class="nav-toggle-no-js">
      <svg width="20" height="20" viewBox="20 20 60 60">
        <path id="ham-top" d="M30,37 L70,37 Z" stroke="currentColor"></path>
        <path id="ham-middle" d="M30,50 L70,50 Z" stroke="currentColor"></path>
        <path id="ham-bottom" d="M30,63 L70,63 Z" stroke="currentColor"></path>
      </svg>
    </summary>

    <ul id="nav-list">
      {
        site?.navigation.map((item: any) => {
          const itemLink = getNavigationLink(item);

          return (
            <li>
              <a
                href={itemLink}
                target={item.target}
                {...helpers.getLinkActiveState(itemLink, pageUrl)}
              >
                {item.text}
              </a>
            </li>
          );
        })
      }
    </ul>
  </details>
</nav>
