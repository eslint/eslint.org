---
interface AccordionItem {
  q: string;
  a: string;
}

interface Props {
  items: AccordionItem[];
}

const { items } = Astro.props;
---

<div data-accordion class="c-accordion">
  {
    items.map((item) => (
      <>
        <h3 data-accordion-heading class="c-accordion__heading">
          {item.q}
        </h3>
        <div data-accordion-panel class="c-accordion__panel" set:html={item.a} />
      </>
    ))
  }
</div>
