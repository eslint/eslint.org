---
interface Props {
  photo?: string | null;
  name: string;
  handle: string;
}

const { photo, name, handle } = Astro.props;
const fallbackImage = "/assets/images/people/_placeholder-avatar.svg";
const imageSrc = photo || fallbackImage;
---

<div class="profile profile--contributor">
  <img
    class="profile__photo profile__photo--medium"
    src={imageSrc}
    width="56"
    height="56"
    alt={name}
    loading="lazy"
    onerror={`this.src = '${fallbackImage}'`}
  />
  <div class="profile__details">
    <div class="profile__name">{name}</div>
    <a href={`https://github.com/${handle}`} class="profile__handle"
      >@{handle}</a
    >
  </div>
</div>
