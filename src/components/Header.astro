---
import { site, links } from "../data/index.js";
import { getLinkActiveState } from "../data/helpers.js";
import Logo from "./Logo.astro";

const pageUrl = Astro.url.pathname;
---
<header class="site-header">
    <div class="content-container">
        <a href="/" aria-label="Homepage" class="logo-link">
            <Logo />
        </a>
        <nav class="site-nav" aria-label="Main">
            <div class="flexer">
                <a href={links.donate} class="c-btn c-btn--primary donate-link">{site.donate_page.title}</a>
                <button class="site-nav-toggle" aria-label="Menu" id="nav-toggle" aria-controls="nav-list">
                    <svg width="20" height="20" viewBox="20 20 60 60">
                        <path id="ham-top" d="M30,37 L70,37 Z" stroke="currentColor"></path>
                        <path id="ham-middle" d="M30,50 L70,50 Z" stroke="currentColor"></path>
                        <path id="ham-bottom" d="M30,63 L70,63 Z" stroke="currentColor"></path>
                    </svg>
                </button>
            </div>
            <ul id="nav-list">
                {site.navigation.map((item) => {
                    const itemLink = links[item.link];
                    const activeAttrs = getLinkActiveState(itemLink, pageUrl);
                    const targetAttr = item.target ? ' target="_blank"' : '';
                    const linkHtml = `<a href="${itemLink}"${activeAttrs}${targetAttr}>${item.text}</a>`;
                    return <li><Fragment set:html={linkHtml} /></li>;
                })}
            </ul>
        </nav>
    </div>
</header>
