---
interface Props {
    image?: string;
    name: string;
    amount: string;
    date?: string;
}

const { image, name, amount, date } = Astro.props;
const fallback_image = '/assets/images/people/_placeholder-avatar.svg';
---
<div class="donation">
    <img class="donation__sponsor-logo" src={image || fallback_image} width="40" height="40" alt={name} onerror={`this.src = '${fallback_image}'`} loading="lazy" />

    <div class="donation__content">
        <p class="donation__sponsor-name">{name}</p>
        <p class="donation__date">{date}</p>
    </div>

    <div class="donation__amount">
        + {amount}
    </div>
</div>
