---
interface Props {
    statValue: number;
    statLabel: string;
}

const { statValue, statLabel } = Astro.props;

function formatStatsNumber(value) {
    const full = new Intl.NumberFormat('en-US').format(value);
    const short = new Intl.NumberFormat('en-US', {
        notation: 'compact',
        compactDisplay: 'short',
        maximumFractionDigits: 1,
    }).format(value);
    return { full, short };
}

const formatted = formatStatsNumber(statValue);
---
<div class="metrics__item" aria-label={`${formatted.full} ${statLabel}`}>
    <span class="metrics__value" aria-hidden="true">{formatted.short}</span>
    <span aria-hidden="true">{statLabel}</span>
</div>
