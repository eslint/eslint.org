---
import fs from "node:fs";
import path from "node:path";
import yaml from "js-yaml";
import { fileURLToPath } from "node:url";
import { site } from "../data/index.js";

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const sitesDir = path.resolve(__dirname, "..", "_data", "sites");
const siteFiles = fs.readdirSync(sitesDir).filter(f => f.endsWith(".yml"));
const sites = {};
for (const f of siteFiles) {
    const key = f.replace(".yml", "");
    sites[key] = yaml.load(fs.readFileSync(path.join(sitesDir, f), "utf8"));
}
---
<ul class="languages-list">
    {Object.entries(sites).map(([key, otherSite]) => (
        <li lang={otherSite.language.code} title={otherSite.language.title}>
            <a href={`https://${otherSite.hostname}`} {...(site.language.code === otherSite.language.code ? { 'aria-current': 'true' } : {})}>
                <span class="flag">{otherSite.language.flag}</span> {otherSite.language.name}
            </a>
        </li>
    ))}
</ul>
